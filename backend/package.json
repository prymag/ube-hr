{
  "name": "ube-hr-backend",
  "version": "1.0.0",
  "description": "UBE HR Management System Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node --require tsconfig-paths/register src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:seed": "ts-node --require tsconfig-paths/register prisma/seed.ts",
    "prisma:studio": "npx prisma studio"
  },
  "keywords": [
    "hr",
    "management"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^7.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.0"
  }
}
