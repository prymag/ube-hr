generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

// Role hierarchy is derived from declaration order (lowest to highest).
// Insert new roles at the correct position — order determines rank.
enum Role {
  USER
  MANAGER
  ADMIN
  SUPER_ADMIN
}

model User {
  id                  Int          @id @default(autoincrement())
  email               String       @unique
  password            String
  name                String?
  role                Role         @default(USER)
  status              UserStatus   @default(ACTIVE)
  profilePicture        String?
  phone               String?
  positionId          Int?
  departmentId        Int?
  deletedAt           DateTime?
  refreshTokenVersion Int          @default(0)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  memberships         Membership[]
  ownedTeams          Team[]       @relation("OwnedTeams")
  verificationCodes   VerificationCode[]
  position            Position?    @relation(fields: [positionId], references: [id])
  department          Department?  @relation("DepartmentMembers", fields: [departmentId], references: [id])
  headOfDepartments   Department[] @relation("DepartmentHead")
}

model Team {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  ownerId     Int
  owner       User         @relation("OwnedTeams", fields: [ownerId], references: [id])
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
}

model RolePermission {
  role       Role
  permission String
  createdAt  DateTime @default(now())

  @@id([role, permission])
}

model Membership {
  userId    Int
  teamId    Int
  joinedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([userId, teamId])
}

model VerificationCode {
  id        Int      @id @default(autoincrement())
  userId    Int
  code      String
  type      String   // 'EMAIL' | 'PHONE'
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Department {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String?
  headId      Int?
  head        User?      @relation("DepartmentHead", fields: [headId], references: [id])
  members     User[]     @relation("DepartmentMembers")
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Position {
  id           Int        @id @default(autoincrement())
  name         String     @unique
  description  String?
  reportsToId  Int?
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  users        User[]
  reportsTo    Position?  @relation("PositionHierarchy", fields: [reportsToId], references: [id])
  reportees    Position[] @relation("PositionHierarchy")
}
