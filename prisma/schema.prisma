generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  USER
  MANAGER
  ADMIN
  SUPER_ADMIN
}

model User {
  id                  Int      @id @default(autoincrement())
  email               String   @unique
  password            String
  name                String?
  role                Role     @default(USER)
  refreshTokenVersion Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
